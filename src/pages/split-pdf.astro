---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolHeader from '../components/ToolHeader.astro';
import SplitTool from '../components/tools/SplitTool.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import RelatedTools from '../components/RelatedTools.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'Split PDF pages online, free — no upload · DontTouchMyDoc';
const description = 'Extract pages from a PDF — one per page or by custom ranges. Runs entirely in your browser, your files never leave your device. Free, no sign-up, no watermarks.';

const steps = [
  { title: 'Open a PDF', body: 'Drop one file; we render each page locally with PDF.js so you can see what you\'re cutting up.' },
  { title: 'Pick extract-all or ranges', body: 'All pages as separate PDFs, or custom ranges like "1-3, 5, 8-10". Each range becomes one output file.' },
  { title: 'Download', body: 'Multiple outputs come zipped. A single range downloads as a single PDF. Names include the page numbers.' },
];

const faq = [
  { q: 'What range syntax do you support?', a: "Comma-separated list of ranges or single pages. Example: <code>1-3, 5, 8-10</code>. Each entry produces one output file." },
  { q: "Why do I only see 60 thumbnails?", a: "We cap previews at 60 pages to keep very large PDFs responsive. The split itself still operates on the full document." },
  { q: 'Does splitting reduce quality?', a: 'No. We lift pages byte-for-byte from the source PDF — text stays selectable, images stay sharp, nothing re-renders.' },
  { q: "Can I split a password-protected PDF?", a: "Not yet. Encrypted files are rejected with an error. Unlock the file first in your native PDF viewer." },
  { q: 'How does the ZIP get built?', a: "Using <a href='https://stuk.github.io/jszip/' class='underline'>JSZip</a>, entirely in-browser. The zip is streamed to a blob URL and handed to your downloader." },
];

const sd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'DontTouchMyDoc Split PDF',
    url: 'https://donttouchmydoc.com/split-pdf',
    applicationCategory: 'Utilities',
    operatingSystem: 'Any (browser-based)',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
    })),
  },
];
---
<BaseLayout title={title} description={description} path="/split-pdf" structuredData={sd}>
  <ToolHeader
    kicker="Tool · 02"
    title="Split PDF"
    tagline="Pull pages out — one by one, or in ranges you define."
    description="Drop a PDF, pick pages, download a clean set of smaller files. Everything happens inside your browser, including the thumbnails."
    accent="navy"
  >
    <svg slot="icon" viewBox="0 0 24 24" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 3h6M6 8h12M3 13h18M6 18h12M9 23h6"/></svg>
  </ToolHeader>

  <SplitTool />
  <AdSlot position="split-under-tool" size="970x250" />
  <HowItWorks steps={steps} heading="Splitting, step by step" />
  <Faq items={faq} heading="Split PDF · FAQ" />
  <AdSlot position="split-faq-bottom" size="728x90" />
  <RelatedTools current="split" />
</BaseLayout>
