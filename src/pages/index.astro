---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ToolGrid from '../components/ToolGrid.astro';
import TrustSection from '../components/TrustSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'DontTouchMyDoc — Private PDF tools. Nothing uploads.';
const description = 'Free PDF tools that run entirely in your browser. Merge, split and compress PDFs — your files never leave your device. No sign-up, no watermarks, no limits.';

const steps = [
  { title: 'Pick a file', body: 'Drag a PDF onto a tool, or browse from your device. Nothing is sent anywhere — the tool lives inside this tab.' },
  { title: 'We process locally', body: 'pdf-lib and PDF.js do the work inside your browser using WebAssembly. Your document stays on your machine.' },
  { title: 'Download the result', body: 'You get a fresh file to save. Close the tab and the traces of what you did evaporate with it.' },
];

const faq = [
  { q: "So you really can't see my files?", a: "Correct. The tool code runs entirely inside your browser. There is no endpoint to upload to and no server-side processing step — the site is a static bundle served from a CDN. You can verify it by opening your browser's network tab while you use a tool." },
  { q: 'Is there a file-size limit?', a: "Technically, no. Practically, your browser's RAM is the ceiling. Most modern browsers handle a few hundred megabytes before getting sluggish. If you're working with very large scans, start with Compress." },
  { q: 'Why is it free?', a: "Because a flat HTML/JS bundle on a CDN costs us almost nothing to serve, and we plan to show a couple of unobtrusive ads around the content. No paywall, no freemium trap." },
  { q: 'Do you support password-protected PDFs?', a: "Not yet. If a file requires a password we'll show a friendly error. Add decrypting your PDF in your native viewer first as a pre-step." },
  { q: 'What about OCR, editing existing text, signing?', a: "Not for now. We only ship tools that can run fully on-device: merge, split, organise, compress, redact, and strip line numbers. Editing existing PDF text reliably needs the original fonts; signing needs secure credential handling — both are on the \"maybe later\" list only if we can do them without a server." },
];

const sd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'DontTouchMyDoc',
    url: 'https://donttouchmydoc.com/',
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'DontTouchMyDoc',
    url: 'https://donttouchmydoc.com/',
    slogan: 'Your docs. Your device. No exceptions.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<BaseLayout title={title} description={description} path="/" structuredData={sd}>
  <Hero />
  <ToolGrid />
  <AdSlot position="home-mid" size="728x90" />
  <TrustSection />
  <HowItWorks steps={steps} heading="Three steps" />
  <Faq items={faq} heading="FAQ" />
  <AdSlot position="home-faq-bottom" size="728x90" />
</BaseLayout>
