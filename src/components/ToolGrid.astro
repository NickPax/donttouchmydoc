---
const tools = [
  {
    href: '/merge-pdf',
    kicker: '01',
    title: 'Merge',
    body: 'Combine any number of PDFs. Drag to re-order, then download one tidy file.',
    cta: 'Merge PDFs',
    accent: 'emerald',
    icon: `<path d="M7 4h8l4 4v12a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z"/><path d="M14 4v5h5"/><path d="M9 14h6M9 17h4" stroke-width="2"/>`,
  },
  {
    href: '/split-pdf',
    kicker: '02',
    title: 'Split',
    body: 'Pull pages out of a PDF — one by one, or by custom ranges like "1-3, 5, 8-10".',
    cta: 'Split a PDF',
    accent: 'navy',
    icon: `<path d="M6 3h9l3 3v5"/><path d="M6 3v18h12V11"/><path d="M10 14h8M10 17h5"/><path d="M2 14l4 3-4 3" fill="none"/>`,
  },
  {
    href: '/organize-pdf',
    kicker: '03',
    title: 'Organise',
    body: 'Rearrange, rotate and delete pages. Drag-and-drop thumbnails, bulk-rotate a batch.',
    cta: 'Organise pages',
    accent: 'emerald',
    icon: `<rect x="3" y="4" width="7" height="7"/><rect x="14" y="4" width="7" height="7"/><rect x="3" y="13" width="7" height="7"/><rect x="14" y="13" width="7" height="7"/>`,
  },
  {
    href: '/compress-pdf',
    kicker: '04',
    title: 'Compress',
    body: 'Shrink scanner-sized PDFs so they fit in email and upload forms. Light, medium, or ruthless.',
    cta: 'Compress PDFs',
    accent: 'amber',
    icon: `<path d="M5 4h14v16H5z"/><path d="M9 9h6M9 12h6M9 15h4"/><path d="M3 11l3-3 3 3M21 13l-3 3-3-3" stroke-width="2.2"/>`,
  },
  {
    href: '/redact-pdf',
    kicker: '05',
    title: 'Redact',
    body: 'Click-and-drag black boxes over anything sensitive. Text underneath is permanently destroyed.',
    cta: 'Redact a PDF',
    accent: 'ink',
    icon: `<rect x="3" y="10" width="18" height="6"/>`,
  },
  {
    href: '/remove-line-numbers',
    kicker: '06',
    title: 'Strip lines',
    body: 'Remove line numbers from court transcripts, legislative drafts, and annotated editions.',
    cta: 'Remove line numbers',
    accent: 'navy',
    icon: `<path d="M3 6h3M3 12h3M3 18h3M10 6h11M10 12h11M10 18h11"/>`,
  },
];
---
<section class="mx-auto max-w-[1320px] px-5 sm:px-8 py-20">
  <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
    <div>
      <div class="section-num">§02 · Tools</div>
      <h2 class="mt-2 display-2">Six tools, zero servers.</h2>
    </div>
    <p class="max-w-md text-sm text-[color-mix(in_srgb,var(--color-ink)_78%,transparent)]">
      Everything below runs inside your browser tab. Close the tab and the files are gone — from us, for real, because we never had them.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {tools.map((t, i) => (
      <a
        href={t.href}
        class:list={[
          'group card p-7 flex flex-col min-h-[300px] relative overflow-hidden transition-transform hover:-translate-y-1',
          // Stagger every 2nd card in lg for editorial rhythm
          (i % 3 === 1) ? 'lg:translate-y-4' : '',
        ]}
      >
        <div class="flex items-start justify-between">
          <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]">
            Tool · {t.kicker}
          </span>
          <span
            class:list={[
              'w-10 h-10 rounded-sm inline-flex items-center justify-center',
              t.accent === 'emerald' && 'bg-[var(--color-emerald-lt)] text-[var(--color-emerald-dk)]',
              t.accent === 'navy'    && 'bg-[var(--color-navy-800)] text-[var(--color-paper)]',
              t.accent === 'amber'   && 'bg-[color-mix(in_srgb,var(--color-amber)_18%,var(--color-cream))] text-[var(--color-amber)]',
              t.accent === 'ink'     && 'bg-[var(--color-ink)] text-[var(--color-paper)]',
            ]}
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" set:html={t.icon}></svg>
          </span>
        </div>

        <h3 class="mt-7 display-2">{t.title}<span class="text-[var(--color-emerald-dk)]">.</span></h3>
        <p class="mt-3 text-[15px] leading-relaxed text-[color-mix(in_srgb,var(--color-ink)_82%,transparent)] max-w-sm">{t.body}</p>

        <div class="mt-auto pt-8 flex items-center justify-between gap-3">
          <span class="font-mono text-[12px] tracking-[0.12em] uppercase group-hover:text-[var(--color-emerald-dk)] transition-colors">
            {t.cta} →
          </span>
          <span class="chip chip-green">Local only</span>
        </div>

        <!-- Decorative corner rule -->
        <span aria-hidden="true" class="absolute right-0 bottom-0 w-16 h-16 border-l border-t border-[var(--color-rule)] translate-x-[65%] translate-y-[65%]"></span>
      </a>
    ))}
  </div>
</section>
