---
// Client-side PDF split tool with PDF.js page previews.
import AdSlot from '../AdSlot.astro';
---
<section id="tool" class="mx-auto max-w-[1320px] px-5 sm:px-8 pt-10 pb-16">
  <div class="grid lg:grid-cols-[minmax(0,1fr)_320px] gap-8">
    <div>
      <!-- Drop zone -->
      <div
        id="dropzone"
        class="drop-target relative rounded-sm p-10 md:p-14 text-center cursor-pointer"
        role="button"
        tabindex="0"
        aria-label="Drop a PDF here or click to browse"
      >
        <div class="scanline rounded-sm" data-scanline hidden></div>
        <div class="relative">
          <div class="mx-auto w-14 h-14 inline-flex items-center justify-center rounded-sm bg-[var(--color-navy-800)] text-[var(--color-paper)]">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3h6M6 8h12M3 13h18M6 18h12M9 23h6"/></svg>
          </div>
          <h2 class="mt-5 display-3">Drop a PDF here.</h2>
          <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">
            Or <button type="button" id="browse" class="underline decoration-[var(--color-emerald-dk)] decoration-2 underline-offset-4">browse from your device</button>.
            Previews render locally, like everything else.
          </p>
        </div>
        <input id="file-input" type="file" accept="application/pdf,.pdf" class="sr-only" />
      </div>

      <!-- Document panel -->
      <div id="doc-panel" class="mt-6 hidden">
        <div class="card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
              <span class="shrink-0 w-10 h-12 border border-[var(--color-rule)] rounded-sm flex items-center justify-center font-display text-[14px] bg-[var(--color-paper)]">PDF</span>
              <div class="min-w-0">
                <div id="doc-name" class="font-display text-[22px] truncate">document.pdf</div>
                <div id="doc-meta" class="font-mono text-[11px] uppercase tracking-[0.14em] text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]">—</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button id="choose-new" class="btn btn-ghost !py-2 !px-3">Swap file</button>
            </div>
          </div>

          <!-- Mode selector -->
          <div class="mt-6 grid sm:grid-cols-2 gap-3" role="radiogroup" aria-label="Split mode">
            <label class="flex items-start gap-3 p-4 rounded-sm border border-[var(--color-rule)] cursor-pointer has-[:checked]:border-[var(--color-emerald-dk)] has-[:checked]:bg-[var(--color-emerald-lt)]">
              <input type="radio" name="mode" value="all" class="mt-1" checked />
              <div>
                <div class="font-display text-[20px] leading-tight">Extract every page.</div>
                <div class="mt-1 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">One PDF per page, zipped into a single download.</div>
              </div>
            </label>
            <label class="flex items-start gap-3 p-4 rounded-sm border border-[var(--color-rule)] cursor-pointer has-[:checked]:border-[var(--color-emerald-dk)] has-[:checked]:bg-[var(--color-emerald-lt)]">
              <input type="radio" name="mode" value="range" class="mt-1" />
              <div>
                <div class="font-display text-[20px] leading-tight">Custom ranges.</div>
                <div class="mt-1 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">Like <span class="font-mono">"1-3, 5, 8-10"</span>. Each range becomes one file.</div>
              </div>
            </label>
          </div>

          <!-- Range input -->
          <div id="range-wrap" class="mt-4 hidden">
            <label for="range-input" class="kicker block mb-1">Ranges · separated by commas</label>
            <input id="range-input" type="text" placeholder="e.g. 1-3, 5, 8-10" autocomplete="off" spellcheck="false" />
            <div id="range-help" class="mt-1.5 font-mono text-[11px] tracking-[0.12em] uppercase text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]">Will produce: —</div>
          </div>

          <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rule pt-5">
            <div class="flex-1 min-w-[240px]">
              <div class="flex items-center justify-between mb-1.5 font-mono text-[11px] tracking-[0.12em] uppercase text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">
                <span id="status-label">Idle</span>
                <span id="progress-num">0%</span>
              </div>
              <div class="bar"><span id="progress-bar" style="width:0%"></span></div>
            </div>
            <button id="split-btn" class="btn btn-primary" disabled>
              Split &amp; download
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 3v14M6 11l6 6 6-6M5 21h14"/></svg>
            </button>
          </div>
        </div>

        <!-- Page thumbnails -->
        <div class="mt-6">
          <div class="flex items-center justify-between mb-3">
            <div class="section-num">Pages</div>
            <div id="thumbs-note" class="font-mono text-[11px] tracking-[0.12em] uppercase text-[color-mix(in_srgb,var(--color-ink)_55%,transparent)]">rendering locally…</div>
          </div>
          <ul id="thumbs" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"></ul>
        </div>
      </div>

      <div id="err" role="alert" class="mt-6 hidden border border-[var(--color-red-stamp)] bg-[color-mix(in_srgb,#f4d6d1_50%,transparent)] text-[var(--color-red-stamp)] font-mono text-xs uppercase tracking-[0.14em] p-3 rounded-sm"></div>
    </div>

    <aside class="space-y-5">
      <div class="card p-5">
        <div class="section-num">Local runtime</div>
        <h3 class="font-display text-[22px] mt-1 leading-tight">What's running?</h3>
        <ul class="mt-3 text-sm space-y-2 font-mono">
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Renderer</span><span>PDF.js</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Splitter</span><span>pdf-lib</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Network</span><span class="text-[var(--color-emerald-dk)]">idle</span></li>
        </ul>
      </div>
      <AdSlot position="split-sidebar" size="300x250" />
      <div class="card-ink p-5">
        <div class="font-mono text-[11px] tracking-[0.2em] uppercase opacity-80">Tip</div>
        <p class="mt-2 text-[15px] leading-relaxed">
          Ranges overlap? That's fine — the output will contain duplicate pages as written. Chaos is <em class="font-display not-italic">allowed</em>.
        </p>
      </div>
    </aside>
  </div>
</section>

<script>
  import { PDFDocument } from 'pdf-lib';
  import JSZip from 'jszip';
  import { formatBytes, downloadBlob, parseRanges } from '../../lib/format.ts';
  import { loadPdfjs } from '../../lib/pdfjs-loader.ts';

  const dropzone = document.getElementById('dropzone') as HTMLDivElement;
  const input    = document.getElementById('file-input') as HTMLInputElement;
  const browse   = document.getElementById('browse') as HTMLButtonElement;
  const chooseNew= document.getElementById('choose-new') as HTMLButtonElement;
  const panel    = document.getElementById('doc-panel') as HTMLDivElement;
  const docName  = document.getElementById('doc-name') as HTMLDivElement;
  const docMeta  = document.getElementById('doc-meta') as HTMLDivElement;
  const thumbs   = document.getElementById('thumbs') as HTMLUListElement;
  const note     = document.getElementById('thumbs-note') as HTMLDivElement;
  const btn      = document.getElementById('split-btn') as HTMLButtonElement;
  const rangeWrap= document.getElementById('range-wrap') as HTMLDivElement;
  const rangeInp = document.getElementById('range-input') as HTMLInputElement;
  const rangeHelp= document.getElementById('range-help') as HTMLDivElement;
  const progBar  = document.getElementById('progress-bar') as HTMLSpanElement;
  const progNum  = document.getElementById('progress-num') as HTMLSpanElement;
  const statusLabel = document.getElementById('status-label') as HTMLSpanElement;
  const errEl    = document.getElementById('err') as HTMLDivElement;
  const scan     = dropzone.querySelector('[data-scanline]') as HTMLDivElement;

  let currentFile: File | null = null;
  let currentDoc: import('pdf-lib').PDFDocument | null = null;
  let totalPages = 0;

  function showErr(msg: string) {
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
    setTimeout(() => errEl.classList.add('hidden'), 6000);
  }
  function setProgress(pct: number, label?: string) {
    const c = Math.max(0, Math.min(100, pct));
    progBar.style.width = `${c}%`;
    progNum.textContent = `${Math.round(c)}%`;
    if (label) statusLabel.textContent = label;
  }

  // Drop zone events
  dropzone.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'browse') return;
    input.click();
  });
  dropzone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); }
  });
  browse.addEventListener('click', (e) => { e.stopPropagation(); input.click(); });
  chooseNew.addEventListener('click', () => input.click());
  ['dragenter', 'dragover'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    dropzone.classList.add('is-dragging');
    if (scan) scan.hidden = false;
  }));
  ['dragleave', 'drop'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    if (evt === 'dragleave' && (e.target !== dropzone)) return;
    dropzone.classList.remove('is-dragging');
    if (scan) scan.hidden = true;
  }));
  dropzone.addEventListener('drop', (e) => {
    const f = e.dataTransfer?.files?.[0];
    if (f) handleFile(f);
  });
  input.addEventListener('change', () => {
    const f = input.files?.[0];
    if (f) handleFile(f);
    input.value = '';
  });

  document.querySelectorAll<HTMLInputElement>('input[name="mode"]').forEach((r) => {
    r.addEventListener('change', () => {
      rangeWrap.classList.toggle('hidden', r.value !== 'range' || !r.checked);
      updateButtonState();
    });
  });
  rangeInp.addEventListener('input', () => {
    const parsed = parseRanges(rangeInp.value, totalPages);
    const n = parsed.length;
    rangeHelp.innerHTML = n
      ? `Will produce: <span style="color:var(--color-emerald-dk)">${n} PDF${n===1?'':'s'}</span>`
      : (rangeInp.value.trim() ? 'No valid ranges detected' : 'Will produce: —');
    updateButtonState();
  });

  function updateButtonState() {
    if (!currentDoc) { btn.disabled = true; return; }
    const mode = (document.querySelector<HTMLInputElement>('input[name="mode"]:checked')?.value) ?? 'all';
    if (mode === 'all') btn.disabled = false;
    else btn.disabled = parseRanges(rangeInp.value, totalPages).length === 0;
  }

  async function handleFile(f: File) {
    if (!(f.type === 'application/pdf' || f.name.toLowerCase().endsWith('.pdf'))) {
      showErr('Only PDF files are accepted.');
      return;
    }
    currentFile = f;
    note.textContent = 'reading…';
    panel.classList.remove('hidden');
    docName.textContent = f.name;
    docMeta.textContent = `${formatBytes(f.size)} · loading…`;
    thumbs.innerHTML = '';

    const buf = await f.arrayBuffer();
    try {
      currentDoc = await PDFDocument.load(buf, { ignoreEncryption: true });
      totalPages = currentDoc.getPageCount();
      docMeta.textContent = `${formatBytes(f.size)} · ${totalPages} page${totalPages===1?'':'s'}`;
      updateButtonState();
      await renderThumbs(buf, totalPages);
    } catch (err) {
      console.error(err);
      currentDoc = null;
      showErr('Could not open this PDF. It may be password-protected or corrupt.');
      docMeta.textContent = `${formatBytes(f.size)} · unreadable`;
    }
  }

  async function renderThumbs(data: ArrayBuffer, pageCount: number) {
    note.textContent = 'rendering locally…';
    // render to a detached buffer copy because pdf-lib already took ownership
    const copy = data.slice(0);
    const pdfjs = await loadPdfjs();
    const loadingTask = pdfjs.getDocument({ data: copy });
    const doc = await loadingTask.promise;
    thumbs.innerHTML = '';
    const max = Math.min(pageCount, 60);
    for (let i = 1; i <= max; i++) {
      const li = document.createElement('li');
      li.className = 'card p-2 flex flex-col items-center';
      li.innerHTML = `
        <div class="w-full aspect-[3/4] bg-[var(--color-paper-2)] rounded-sm overflow-hidden border border-[var(--color-rule)] flex items-center justify-center relative">
          <span class="font-mono text-[10px] tracking-[0.15em] uppercase text-[color-mix(in_srgb,var(--color-ink)_55%,transparent)]">page ${i}</span>
        </div>
        <div class="mt-1.5 self-stretch flex items-center justify-between font-mono text-[10px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_55%,transparent)]">
          <span>${String(i).padStart(3,'0')}</span>
          <span class="text-[var(--color-emerald-dk)]">local</span>
        </div>
      `;
      thumbs.appendChild(li);

      // Render async
      (async () => {
        try {
          const page = await doc.getPage(i);
          const vp   = page.getViewport({ scale: 1 });
          const scale = Math.min(180 / vp.width, 240 / vp.height);
          const v    = page.getViewport({ scale });
          const canvas = document.createElement('canvas');
          canvas.width  = Math.floor(v.width * (window.devicePixelRatio || 1));
          canvas.height = Math.floor(v.height * (window.devicePixelRatio || 1));
          canvas.style.width  = `${Math.floor(v.width)}px`;
          canvas.style.height = `${Math.floor(v.height)}px`;
          const ctx = canvas.getContext('2d')!;
          ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
          await page.render({ canvasContext: ctx, viewport: v }).promise;
          const box = li.querySelector('div') as HTMLDivElement;
          box.innerHTML = '';
          box.appendChild(canvas);
          canvas.className = 'max-w-full max-h-full';
        } catch (e) {
          // leave placeholder
        }
      })();
    }
    if (pageCount > max) {
      const li = document.createElement('li');
      li.className = 'card p-4 flex items-center justify-center text-center text-xs font-mono text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)] uppercase tracking-[0.12em]';
      li.textContent = `+${pageCount - max} more pages · not previewed`;
      thumbs.appendChild(li);
    }
    note.textContent = `${Math.min(pageCount, max)} of ${pageCount} previewed`;
  }

  btn.addEventListener('click', async () => {
    if (!currentFile || !currentDoc) return;
    btn.disabled = true;
    const mode = (document.querySelector<HTMLInputElement>('input[name="mode"]:checked')?.value) ?? 'all';
    try {
      const baseName = currentFile.name.replace(/\.pdf$/i, '') || 'document';

      if (mode === 'all') {
        setProgress(2, 'Preparing pages');
        const zip = new JSZip();
        const srcBytes = await currentFile.arrayBuffer();
        for (let i = 0; i < totalPages; i++) {
          setProgress(2 + (i / totalPages) * 94, `Page ${i + 1} / ${totalPages}`);
          const src = await PDFDocument.load(srcBytes, { ignoreEncryption: true });
          const out = await PDFDocument.create();
          const [p] = await out.copyPages(src, [i]);
          out.addPage(p);
          const bytes = await out.save({ useObjectStreams: true });
          zip.file(`${baseName}-page-${String(i + 1).padStart(3, '0')}.pdf`, bytes);
        }
        setProgress(98, 'Packing zip');
        const blob = await zip.generateAsync({ type: 'blob' });
        setProgress(100, 'Done');
        downloadBlob(blob, `${baseName}-pages.zip`);
      } else {
        const ranges = parseRanges(rangeInp.value, totalPages);
        if (!ranges.length) { showErr('Type at least one valid range.'); return; }
        const zip = new JSZip();
        const srcBytes = await currentFile.arrayBuffer();
        const total = ranges.length;
        const outputs: { name: string; bytes: Uint8Array }[] = [];
        for (let i = 0; i < total; i++) {
          const r = ranges[i];
          setProgress(2 + (i / total) * 94, `Range ${i + 1} / ${total}`);
          const src = await PDFDocument.load(srcBytes, { ignoreEncryption: true });
          const out = await PDFDocument.create();
          const pages = await out.copyPages(src, r.map((n) => n - 1));
          pages.forEach((p) => out.addPage(p));
          const bytes = await out.save({ useObjectStreams: true });
          const label = r.length === 1 ? `p${r[0]}` : `p${r[0]}-${r[r.length-1]}`;
          outputs.push({ name: `${baseName}-${label}.pdf`, bytes });
        }
        if (outputs.length === 1) {
          setProgress(100, 'Done');
          downloadBlob(new Blob([outputs[0].bytes], { type: 'application/pdf' }), outputs[0].name);
        } else {
          outputs.forEach((o) => zip.file(o.name, o.bytes));
          setProgress(98, 'Packing zip');
          const blob = await zip.generateAsync({ type: 'blob' });
          setProgress(100, 'Done');
          downloadBlob(blob, `${baseName}-split.zip`);
        }
      }
      setTimeout(() => setProgress(0, 'Idle'), 1500);
    } catch (err) {
      console.error(err);
      showErr('Couldn\'t split this PDF. It may be password-protected or corrupt.');
      setProgress(0, 'Idle');
    } finally {
      updateButtonState();
    }
  });
</script>
