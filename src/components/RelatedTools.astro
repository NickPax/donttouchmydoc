---
type Props = { current: 'merge' | 'split' | 'organize' | 'compress' | 'redact' | 'remove-lines' };
const { current } = Astro.props;

const all = [
  { id: 'merge',         href: '/merge-pdf',           title: 'Merge PDFs',           sub: 'Combine files, keep your order.' },
  { id: 'split',         href: '/split-pdf',           title: 'Split PDF',            sub: 'Pull pages out, one or in ranges.' },
  { id: 'organize',      href: '/organize-pdf',        title: 'Organise pages',       sub: 'Rearrange, rotate, delete.' },
  { id: 'compress',      href: '/compress-pdf',        title: 'Compress PDF',         sub: 'Make files smaller. No cloud.' },
  { id: 'redact',        href: '/redact-pdf',          title: 'Redact PDF',           sub: 'Black out sensitive bits, for real.' },
  { id: 'remove-lines',  href: '/remove-line-numbers', title: 'Remove line numbers',  sub: 'Clean up court transcripts.' },
] as const;
const others = all.filter((t) => t.id !== current);
---
<section class="mx-auto max-w-[1320px] px-5 sm:px-8 py-20">
  <div class="flex items-end justify-between gap-6 mb-6">
    <div>
      <div class="section-num">§05 · See also</div>
      <h2 class="mt-2 display-3">Other tools.</h2>
    </div>
    <a href="/" class="hidden sm:inline font-mono text-xs uppercase tracking-[0.14em] underline underline-offset-4 decoration-[var(--color-emerald-dk)] decoration-2">All tools →</a>
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {others.map((t) => (
      <a href={t.href} class="card p-6 flex items-center justify-between gap-6 hover:bg-[var(--color-paper-2)] transition-colors">
        <div>
          <h3 class="font-display text-[26px] leading-tight">{t.title}.</h3>
          <p class="mt-1 text-sm text-[color-mix(in_srgb,var(--color-ink)_80%,transparent)]">{t.sub}</p>
        </div>
        <span class="shrink-0 w-11 h-11 inline-flex items-center justify-center bg-[var(--color-navy-800)] text-[var(--color-paper)] rounded-sm">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>
